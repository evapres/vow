# Copy to `.env.local` and fill in. Never commit real secrets.

# Supabase (https://supabase.com/dashboard/project/_/settings/api)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Public site URL for invite links in emails (optional if you always open the app from the same host)
NEXT_PUBLIC_SITE_URL=

# Resend — required to send invitation emails (https://resend.com/api-keys)
RESEND_API_KEY=

# IANA zone for naive wedding_date strings without offset (default Europe/Athens)
WEDDING_EVENT_TIME_ZONE=
