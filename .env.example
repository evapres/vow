# Copy to `.env.local` and fill in. Never commit real secrets.

# Supabase (https://supabase.com/dashboard/project/_/settings/api)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Required for `npm run dev:login-link` when Supabase blocks OTP emails (local dev only).
SUPABASE_SERVICE_ROLE_KEY=

# Public site URL for invite emails (e.g. https://thevow.vip). Also set the same URL as Supabase Auth → URL Configuration → Site URL.
NEXT_PUBLIC_SITE_URL=

# Supabase Auth (Dashboard → Authentication → URL configuration):
# - Site URL: same as NEXT_PUBLIC_SITE_URL (e.g. http://localhost:3000 in dev)
# - Redirect URLs (add both): http://localhost:3000/auth/callback** and https://your-domain.com/auth/callback**
# - Providers → Email: enable Email / magic link

# Optional — Facebook app id for Messenger “Send” dialog in the dashboard (otherwise copy link + mobile deep link).
# NEXT_PUBLIC_FACEBOOK_APP_ID=

# Invitation page background music (default /invitation-music.mp3 in /public)
NEXT_PUBLIC_INVITATION_MUSIC_URL=

# Resend — required for invitation emails and RSVP alerts to the wedding owner (https://resend.com/api-keys)
RESEND_API_KEY=

# IANA zone for naive wedding_date strings without offset (default Europe/Athens)
WEDDING_EVENT_TIME_ZONE=
