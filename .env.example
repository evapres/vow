# Copy to `.env.local` and fill in. Never commit real secrets.

# Supabase (https://supabase.com/dashboard/project/_/settings/api)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role — required for guest RSVP submit, reliable dashboard RSVP reads, and deletes if RLS blocks the owner JWT.
# Copy from Supabase → Project Settings → API → service_role (secret). Same value as on Vercel.
SUPABASE_SERVICE_ROLE_KEY=

# Public site URL for invite emails (e.g. https://thevow.vip). Also set the same URL as Supabase Auth → URL Configuration → Site URL.
NEXT_PUBLIC_SITE_URL=

# Supabase Auth (Dashboard → Authentication → URL configuration):
# - Site URL: https://thevow.vip (production); keep http://localhost:3000 for local-only testing if needed
# - Redirect URLs: http://localhost:3000/** and https://thevow.vip/auth/callback**
# - Providers → Email: enable Email / magic link
#
# Local login (same as production):
# - SUPABASE_SERVICE_ROLE_KEY — required on localhost (copy from Vercel / Supabase API settings)
# - RESEND_API_KEY — optional locally; when set, “Send magic link” emails you like production.
#   Without Resend, the same sign-in link appears on the login page after you submit.

# Optional — Facebook app id for Messenger “Send” dialog in the dashboard (otherwise copy link + mobile deep link).
# NEXT_PUBLIC_FACEBOOK_APP_ID=

# Invitation page background music (default /invitation-music.mp3 in /public)
NEXT_PUBLIC_INVITATION_MUSIC_URL=

# Resend — invitation emails, RSVP alerts, and admin login magic links (https://resend.com/api-keys)
RESEND_API_KEY=

# IANA zone for naive wedding_date strings without offset (default Europe/Athens)
WEDDING_EVENT_TIME_ZONE=
